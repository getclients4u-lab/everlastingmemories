{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.{jpg,jpeg,png,gif,webp,svg,ico,css,js,json}",
      "use": "@vercel/static"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "ADMIN_TOKEN": "em-admin-2026",
    "ADMIN_USER": "admin",
    "ADMIN_PASS": "Everlasting2026!"
  }
}